# =============================================================================
# MetaAgent 环境变量配置模板
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 填写实际配置值
#   3. .env 文件已添加到 .gitignore，不会提交到仓库
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API 配置
# -----------------------------------------------------------------------------
# OpenAI API 密钥（必填）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API 基础 URL（可选，使用自定义代理时填写）
# OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # 生产环境建议设置密码

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
META_AGENT_ENVIRONMENT=production
META_AGENT_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 监控配置
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin123  # 首次登录后请修改
