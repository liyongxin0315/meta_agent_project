# =============================================================================
# MetaAgent 环境变量配置模板
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 填写实际配置值
#   3. .env 文件已添加到 .gitignore，不会提交到仓库
# =============================================================================

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
APP_NAME=MetaAgent
APP_VERSION=1.0.0
META_AGENT_ENV=development

# -----------------------------------------------------------------------------
# LLM API 配置
# -----------------------------------------------------------------------------
# OpenAI API 密钥（必填）
LLM_API_KEY=sk-your-api-key-here

# OpenAI API 基础 URL（可选）
LLM_BASE_URL=https://api.openai.com/v1

# 模型选择
LLM_MODEL=gpt-4
LLM_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# 监控配置
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin123
