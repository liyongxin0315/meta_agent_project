# =============================================================================
# MetaAgent .gitignore - Python 项目最佳实践
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# 字节编译文件
__pycache__/
*.py[cod]
*$py.class

# 分发/打包
dist/
build/
*.egg-info/
*.egg

# 虚拟环境
.env
.venv/
venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# 测试
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# 类型检查
# -----------------------------------------------------------------------------
.mypy_cache/
.pytype/

# -----------------------------------------------------------------------------
# 构建工具
# -----------------------------------------------------------------------------
# Poetry
poetry.lock

# pip
*.manifest
*.spec

# -----------------------------------------------------------------------------
# 环境配置
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# 日志
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# 操作系统
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# 项目特定
# -----------------------------------------------------------------------------
# 数据文件（可选）
data/*.db
data/*.sqlite

# 临时文件
tmp/
temp/
.cache/
