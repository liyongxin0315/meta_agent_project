# =============================================================================
# MetaAgent .gitignore - 跨平台 + 混合语言配置
# =============================================================================

# -----------------------------------------------------------------------------
# Python 缓存和构建产物
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Python 虚拟环境
.venv/
venv/
env/
ENV/
.env

# -----------------------------------------------------------------------------
# Go 忽略项
# -----------------------------------------------------------------------------
**/go.sum
**/go.mod
**/bin/
**/pkg/
*.exe
**/*.exe
**/*.dll
**/*.so
**/*.dylib

# -----------------------------------------------------------------------------
# Rust 忽略项
# -----------------------------------------------------------------------------
**/Cargo.lock
**/target/
**/*.rs.bk

# -----------------------------------------------------------------------------
# C++ 忽略项
# -----------------------------------------------------------------------------
**/cmake-build-debug/
**/cmake-build-release/
**/CMakeCache.txt
**/CMakeFiles/
*.o
*.obj
*.a
*.lib

# -----------------------------------------------------------------------------
# 跨平台构建忽略
# -----------------------------------------------------------------------------
**/dist/
**/build/
**/*.tar.gz
**/*.zip
**/*.whl

# -----------------------------------------------------------------------------
# 测试缓存
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.log

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore
docker-compose.override.yml
*.log

# -----------------------------------------------------------------------------
# IDE 配置
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS 系统文件
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# 敏感信息
# -----------------------------------------------------------------------------
secrets/
*.key
*.pem
*.crt
!*.pub
*.env.local
*.env.production

# -----------------------------------------------------------------------------
# 数据和日志（可选，根据项目需求）
# -----------------------------------------------------------------------------
data/*.db
data/*.sqlite
logs/*.log
logs/*.json
